# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
GOOGLE_API_KEY=your_google_ai_studio_key_here

# --- Backbone + judge ---
BACKBONE_MODEL=gpt-4o-mini
JUDGE_PROVIDER=google
JUDGE_MODEL=gemini-2.5-flash
BACKBONE_TEMPERATURE=0
JUDGE_TEMPERATURE=0
MAX_TOKENS=512

# --- Local Mem0 / Letta setup ---
BENCH_SYSTEMS=mem0,letta
MEM0_CHROMA_PATH=./mem0_store
MEM0_COLLECTION_NAME=locomo_bench
LETTA_BASE_URL=http://localhost:8283
LETTA_API_KEY=local-dev-token
ZEP_BASE_URL=http://localhost:8000
# Only needed if BENCH_SYSTEMS includes zep
ZEP_API_KEY=local-dev-token
ZEP_SEARCH_LIMIT=10

# --- Paths ---
COGNITIVE_SAMPLES_PATH=./data/cognitive_samples.json
RESULTS_DIR=./results

# --- Runtime ---
REQUEST_TIMEOUT_SECONDS=60
RETRY_MAX_ATTEMPTS=3
INGEST_BATCH_SIZE=20
MEM0_INFER=true
MEM0_SEARCH_LIMIT=10
MEM0_TELEMETRY=false
